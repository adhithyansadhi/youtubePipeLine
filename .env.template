# YouTube Shorts Multi-Agent System - Environment Config
# Copy this file to .env and fill in your values

# -- Required (Script + Content Generation) ────────────────────────────────
# Get your key from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Gemini model to use for all agents. Change this to switch models.
# Options (all free-tier friendly):
#   gemini-2.0-flash          (default, fast, supports most keys)
#   gemini-2.0-flash-lite     (lighter, faster, very quota-friendly)
#   gemini-1.5-flash          (stable, widely supported)
#   gemini-1.5-flash-8b       (smallest, fastest, good for testing)
#   gemini-1.5-pro            (higher quality, slower, lower quota)
GEMINI_MODEL=gemini-1.5-flash


# -- Required (Video Rendering) ────────────────────────────────────────────
# Get your free key from: https://www.pexels.com/api/
# Without this key, video rendering is skipped (script/markdown output still works)
PEXELS_API_KEY=your_pexels_api_key_here

# -- Optional ──────────────────────────────────────────────────────────────
# Number of Shorts to generate per run (1-5, default: 3)
NUM_SHORTS=3

# Set to "true" to run without making real API calls (demo/test mode)
MOCK_MODE=false

# Set to "true" to skip video rendering even if PEXELS_API_KEY is set
SKIP_VIDEO_RENDER=false
